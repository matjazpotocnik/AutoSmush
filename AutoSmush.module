<?php namespace ProcessWire;

use Exception;
use ImageOptimizer\Exception\Exception as ImageOptimizerException;
use ImageOptimizer\OptimizerFactory;

require_once __DIR__ . '/image-optimizer/vendor/autoload.php';

/**
 * @phpstan-type AutoSmushConfigData array{
 *   optAutoEngine: string,
 *   optAutoAction: list<string>,
 *   optAutoQuality: string,
 *   optApiEngine: string,
 *   optApiAction: list<string>,
 *   optApiQuality: string,
 *   optManualEngine: string,
 *   optManualAction: list<string>,
 *   optManualQuality: string,
 *   optBulkEngine: string,
 *   optBulkAction: list<string>,
 *   optBulkQuality: string,
 *   optChain: int|string,
 *   optNoExif: int|string,
 * }
 *
 * AutoSmush
 * Optimize images
 *
 * @version 2.0.0
 * @author Roland Toth (tpr)
 * @author Matjaz Potocnik (matjazp)
 * @link https://github.com/matjazpotocnik/AutoSmush
 *
 * https://processwire.com
 *
 */
class AutoSmush extends FieldtypeImage implements Module, ConfigurableModule {

	/**
	 * Module info
	 *
	 * @return array<string,string|bool>
	 */
	public static function getModuleInfo() {
		return [
			'title'    => 'Auto Smush',
			'class'    => 'AutoSmush',
			'author'   => 'Roland Toth, Matjaž Potočnik',
			'version'  => '2.0.0',
			'summary'  => 'Optimize/compress images automatically on upload, resize and crop, ' .
										'manually by clicking the button or link for each image or variation, ' .
										'and in bulk mode for all images sitewide.',
			'href'     => 'https://processwire.com/talk/topic/14818-auto-smush/',
			'requires' => 'ProcessWire>=3.0.212, PHP>=8.1',
			'icon'     => 'leaf',
			'singular' => true,
			'autoload' => true
		];
	}

	/**
	 * Module configuraton values
	 */
	const WEBSERVICE = 'http://api.resmush.it/ws.php?exif=true&img=';
	const WEBSERVICE_NOEXIF = 'http://api.resmush.it/ws.php?img=';
	const API_SIZELIMIT = 5242880; // 5 MB limit
	const API_ALLOWED_EXTENSIONS = 'png, jpg, jpeg, gif';
	const JPG_QUALITY_DEFAULT = '90';
	const CONNECTION_TIMEOUT = 30; // for large images and slow connection 30 sec might not be enough
	const JPG_QUALITY_THRESHOLD = 5; // no optimization if gain is less than 5%, only for jpegoptim, should prevent reoptmizing

	/**
	 * Array of messages reported by this module
	 * @var array<string,string>
	 */
	private $msgs = [];

	/**
	 * Array of settings for image-optimizer
	 * @var array<string,mixed>
	 */
	protected $optimizeSettings = [];

	/**
	 * Array of all optimizers
	 * @var array<string, string>
	 */
	protected $optimizers = [];

	/**
	 * Array of additional paths to look for optimizer executables
	 * @var string[]
	 */
	protected $optimizersExtraPaths = [];

	/**
	 * Array of allowed extensions for images
	 * @var string[]
	 */
	protected $allowedExtensions = [];

	/**
	 * Array of error codes returned by reSmush.it web service
	 * @var array<int, string>
	 */
	private $apiErrorCodes = [];

	/**
	 * Indicator if image needs to be optimized
	 * @var boolean
	 */
	private $isOptimizeNeeded = false;

	/**
	 * Indicator if image was optimized on upload
	 * @var boolean
	 */
	private $isOptimizedOnUpload = false;

	/**
	 * This module config data
	 *
	 * @var AutoSmushConfigData
	 */
	protected $configData;


	/**
	 * Construct and set default configuration.
	 *
	 * @return void
	 */
	public function __construct() {

		$this->msgs = [
			'start'            => $this->_('Starting...'),
			'complete'         => $this->_('All done'),
			'error'            => $this->_('ERROR:'),
			'save_first'       => $this->_('Module settings have been modified, please save first'),
			'confirm'          => $this->_('Are you sure to continue?'),
			'canceled'         => $this->_('Canceled'),
			'canceling'        => $this->_('Canceling...'),
			'filelist'         => $this->_('Generating list of images'),
			'filelistnum'      => $this->_('Number of images: '),
			'actions'          => $this->_('Actions'),
			'engine'           => $this->_('Engine'),
			'eng_resmushit'    => $this->_('Use reShmush.it online service'),
			'eng_localtools'   => $this->_('Use optimization tools available on the web server'),
			'jpg_quality'      => $this->_('JPG quality'),
			'demo'             => $this->_('Optimization disabled in demo mode'),
		];

		$this->configData = [
			'optAutoEngine' => 'resmushit',
			'optAutoAction' => [],
			'optAutoQuality' => self::JPG_QUALITY_DEFAULT,
			'optApiEngine' => 'resmushit',
			'optApiAction' => [],
			'optApiQuality' => self::JPG_QUALITY_DEFAULT,
			'optManualEngine' => 'resmushit',
			'optManualAction' => ['optimize_originals', 'optimize_variations'],
			'optManualQuality' => self::JPG_QUALITY_DEFAULT,
			'optBulkEngine' => 'resmushit',
			'optBulkAction' => [],
			'optBulkQuality' => self::JPG_QUALITY_DEFAULT,
			'optChain' => '',
			'optNoExif' => '',
		];

		$this->optimizers = [
			'jpegtran'  => '',
			'jpegoptim' => '',
			'pngquant'  => '',
			'optipng'   => '',
			'pngcrush'  => '',
			'pngout'    => '',
			'advpng'    => '',
			'gifsicle'  => '',
			'svgo'      => ''
		];

		// currently only jpegoptim is used for jpegs, I modified OptimizerFactory.php
		// pngs are chained in this order: pngquant, optipng, pngcrush, advpng
		$this->optimizeSettings = [
			'ignore_errors'     => false, // in production could be set to true
			'execute_first'     => true, // true: execute just first optimizer in chain, false: execute all optimizers in chain
			'jpegtran_options'  => ['-optimize', '-progressive', '-copy', 'all'],
			'jpegoptim_options' => ['--preserve', '--all-progressive', '--strip-none', '-T' . self::JPG_QUALITY_THRESHOLD],
			'optipng_options'   => ['-i0', '-o2', '-quiet', '-preserve'],
			'advpng_options'    => ['-z', '-3', '-q'],
			'svgo_options'      => ['--disable=cleanupIDs']
		];

		$this->allowedExtensions = array_map('trim', explode(',', self::API_ALLOWED_EXTENSIONS . ', svg'));

		// http://resmush.it/api
		$this->apiErrorCodes = [
			'400' => $this->_('No image URL provided.'),
			'401' => $this->_('Unable to fetch the image from the URL (usually because it is a local URL).'),
			'402' => $this->_('Unable to fetch the image from $_FILES (usually because it is a local URL).'),
			'403' => $this->_('Forbidden file format. Supported formats are jpg, png, gif, tif and bmp.'),
			'404' => $this->_('Request timed out from reSmush.it.'),
			'501' => $this->_('Internal error: cannot create a local copy.'),
			'502' => $this->_('Image too large (must be below 5MB).'),
			'503' => $this->_('Internal error: could not reach remote reSmush.it servers for image optimization.'),
			'504' => $this->_('Internal error: could not fetch the image from remote reSmush.it servers.')
		];

	}


	/**
	 * Initialize log file and optimizer executable search paths.
	 *
	 * @return void
	 */
	public function init() {
		$paths = $this->wire()->config->paths;

		$this->optimizersExtraPaths = array_values(array_filter([
			realpath("{$paths->siteModules}$this/windows_binaries"),
			realpath($paths->root),
			realpath($paths->templates),
			realpath($paths->assets)
		]));
	}

	/**
	 * Main entry point.
	 * Set hooks and handle AJAX optimization requests.
	 *
	 * @return void
	 */
	public function ready() {

		$moduleConfig = $this->wire()->modules->getConfig($this);
		/** @var AutoSmushConfigData $configData */
		$configData = array_merge($this->configData, is_array($moduleConfig) ? $moduleConfig : []);
		$this->configData = $configData;

		$config = $this->wire()->config;
		$input = $this->wire()->input;
		$page = $this->wire()->page;

		$this->checkOptimizers();
		foreach($this->optimizers as $optimizer => $path) $this->optimizeSettings[$optimizer . '_bin'] = $path;
		if((int) $this->configData['optChain'] === 1) $this->optimizeSettings['execute_first'] = false;

		// handle ajax optimization calls
		if($input->get('name') === "$this") {

			// optimize images in bulk mode on button click
			// this method halts execution
			if($input->get('mode') === 'bulk') $this->bulkOptimize();

			// optimize images in manual mode on clicking optimize button/link or on image variations modal
			// this method halts execution
			if($input->get('mode') === 'optimize') $this->onclickOptimize(($input->get('var') === '1')); // &var=1 => process variation

			// add assets
			$this->wire()->modules->get('JqueryMagnific');
			$config->scripts->add("{$config->urls->siteModules}$this/$this.js");
			$config->styles->add("{$config->urls->siteModules}$this/$this.css");
		}

		// add optimize button/link in manual mode on page/image edit
		if($page->process === 'ProcessPageEdit' || $page->process === 'ProcessPageEditImageSelect') {
			if(in_array('optimize_originals', $this->configData['optManualAction'])) {
				// add optimize button via getImageEditButtons hook (available since PW 3.0.212)
				$this->addHookAfter('InputfieldImage::getImageEditButtons', $this, 'addOptButton');
			}
			if(in_array('optimize_variations', $this->configData['optManualAction'])) {
				// add button on variations page
				// for new image field introduced after 3.0.17 we could hook after InputfieldImage::renderButtons
				//$this->log->save("addhookafter ProcessPageEditImageSelect::executeVariations in admin");
				$this->addHookAfter('ProcessPageEditImageSelect::executeVariations', $this, 'addOptButtonVariations');
			}
			if(in_array('optimize_originals', $this->configData['optManualAction']) ||
				in_array('optimize_variations', $this->configData['optManualAction'])) {
				$config->scripts->add("{$config->urls->siteModules}$this/{$this}PageEdit.js");
			}
		}

		// disable automatic mode when site is in demo mode
		if($config->demo) return;

		// is this check enough?
		$isAdmin = ($page->template == 'admin');

		// optimize images in auto mode on resize in admin
		if($isAdmin &&
			(in_array('optimize_variations', $this->configData['optAutoAction']) || in_array('optimize_variationsCI3', $this->configData['optAutoAction']))) {
			//$this->log->save("addhookafter ImageSizer::resize and Pageimage::size in admin");
			$this->addHookAfter('ImageSizer::resize', $this, 'checkOptimizeNeeded');
			$this->addHookAfter('Pageimage::size', $this, 'optimizeOnResize');
			if((
				$this->wire()->modules->isInstalled('FieldtypeCroppableImage4') ||
				$this->wire()->modules->isInstalled('FieldtypeCroppableImage3')
			) && in_array('optimize_variationsCI3', $this->configData['optAutoAction'])) {
				//$this->log->save("addhookafter ProcessCroppableImageX::executeSave and Pageimage::getCrop in admin");
				if($this->wire()->modules->isInstalled('FieldtypeCroppableImage4')) {
					$this->addHookAfter('ProcessCroppableImage4::executeSave', $this, 'optimizeOnResizeCI3'); // optimize on save in CI4 modal
				} else {
					$this->addHookAfter('ProcessCroppableImage3::executeSave', $this, 'optimizeOnResizeCI3'); // optimize on save in CI3 modal
				}
				$this->addHookAfter('Pageimage::getCrop', $this, 'optimizeOnResize'); // optimize on CroppableImage crop generation
			}
		}

		// optimize images in auto mode on pageimage->size() method in templates
		if(!$isAdmin &&
			in_array('optimize_variations', $this->configData['optApiAction'])) {
			//$this->log->save("addhookafter ImageSizer::resize and Pageimage::size in templates");
			$this->addHookAfter('ImageSizer::resize', $this, 'checkOptimizeNeeded');
			$this->addHookAfter('Pageimage::size', $this, 'optimizeOnResizeAPI');
		}

		// optimize images in auto mode on upload in admin
		// should I hook only in ProcessPageEdit?
		if($isAdmin && in_array('optimize_originals', $this->configData['optAutoAction'])) {
			//$this->log->save("addhookbefore InputfieldFile::fileAdded in admin");
			$this->addHookBefore('InputfieldFile::fileAdded', $this, 'optimizeOnUpload', ['priority'=>200]); //in admin
			$config->js('uploadSpinnerMsg', $this->_('Optimizing'));
			// delete backup copy - maybe this should run in all cases?
			if(in_array('backup', $this->configData['optAutoAction'])) {
				$this->addHookAfter('InputfieldFile::processInputDeleteFile', $this, 'deleteBackup');
			}
		}

		// optimize images in auto mode on pageimage->add() method in templates
		if(!$isAdmin && in_array('optimize_originals', $this->configData['optApiAction'])) {
			//$this->log->save("addhookafter Pagefile::install in templates");
			$this->addHookAfter('Pagefile::install', $this, 'optimizeOnAdd', ['priority'=>200]); //in templates
			// delete backup copy - maybe this should run in all cases?
			//if(in_array('backup', $this->configData['optAutoAction'])) {
			//	$this->addHookAfter('InputfieldFile::processInputDeleteFile', $this, 'deleteBackup');
			//}
		}

		// optimize images in auto mode on pageimage->url() method in templates
		if(!$isAdmin && in_array('optimize_auto', $this->configData['optApiAction'])) {
			//$this->log->save('addhookafter Pagefile::url in templates');
			$this->addHookAfter('Pageimage::url', $this, 'optimizeOnUrl', ['priority'=>201]);
		}

	}

	/**
	 * Hook after ImageSizer::resize in auto mode.
	 * Just set the flag that image was resized and should be optimized if needed.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function checkOptimizeNeeded($event) {
		$this->isOptimizeNeeded = true;
	}

	/**
	 * Hook after Pageimage::size in auto mode.
	 * Optimize image on resize/crop.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnResize($event) {
		$thumb = $event->return;
		if(!$thumb instanceof Pageimage) return;

		$this->optimize($thumb, false, 'auto');
		$this->isOptimizeNeeded = false;

		$event->return = $thumb;
	}

	/**
	 * Hook after Pageimage::size in API mode.
	 * Optimize image on resize/crop.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnResizeAPI($event) {
		$thumb = $event->return;
		if(!$thumb instanceof Pageimage) return;

		$this->optimize($thumb, false, 'api');
		$this->isOptimizeNeeded = false;

		$event->return = $thumb;
	}

	/**
	 * Hook after CroppableImage crop save in auto mode.
	 * Optimize image on crop when CroppableImage3 or CroppableImage4 is installed.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnResizeCI3($event) {

		// get page-id from post, sanitize, validate page and edit permission
		$id = $this->input->post->int('pages_id');
		$page = $this->wire()->pages->get($id);
		if(!$page->id) throw new WireException('Invalid page');
		$editable = $page instanceof RepeaterPage ? $page->getForPage()->editable() : $page->editable();
		if(!$editable) throw new WirePermissionException('Not Editable');

		// get fieldname from post, sanitize and validate
		$rawField = $this->wire()->sanitizer->fieldName($this->input->post->text('field'));
		$f = $page->fields->get($rawField);
		$fieldName = $f instanceof Field ? $f->name : $rawField;

		$field = $page->get($fieldName);
		if(!$field instanceof Pagefiles) throw new WireException('Invalid field');

		// get filename from post, sanitize and validate
		$filename = $this->wire()->sanitizer->name($this->input->post->name('filename'));

		// $img is not variation
		$img = $field->get('name=' . $filename);
		if(!$img instanceof Pageimage) throw new WireException('Invalid image filename');

		// get suffix from post, sanitize and validate
		$suffix = $this->wire()->sanitizer->name($this->input->post->name('suffix'));
		if(!$suffix) throw new WireException('No suffix');

		// build the file
		$file = basename($img->basename, '.' . $img->ext) . '.-' . $suffix . '.' . $img->ext;

		// get the variation
		$variations = $img->getVariations();
		if(!$variations instanceof Pageimages) throw new WireException('Invalid variation');
		$myimage = $variations->get($file);
		if(!$myimage instanceof Pageimage) throw new WireException('Invalid variation filename');

		$this->optimize($myimage, false, 'auto');
		$this->isOptimizeNeeded = false;

	}

	/**
	 * Hook before InputfieldFile::fileAdded in auto mode.
	 * Optimize image on upload in the admin interface.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnUpload($event) {
		$img = $event->argumentsByName('pagefile');
		if(!$img instanceof Pageimage) return;
		$this->prepareAndOptimize($img, 'auto', $this->configData['optAutoEngine'], $this->configData['optAutoAction'], true);
	}

	/**
	 * Hook after Pageimage::install in auto mode.
	 * Optimize image on API $page->add() call.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnAdd($event) {
		$img = $event->object;
		if(!$img instanceof Pageimage) return;
		$this->prepareAndOptimize($img, 'api', $this->configData['optApiEngine'], $this->configData['optApiAction']);
	}

	/**
	 * Validate, optionally backup, and optimize an image.
	 *
	 * @param Pageimage $img
	 * @param string $mode 'auto' or 'api'
	 * @param string $engine Engine config value
	 * @param list<string> $actions Action config array
	 * @param bool $isAdminUpload When true and SVG is skipped, clears the JS config key that
	 *                            drives the "Optimizing…" spinner in AutoSmushPageEdit.js,
	 *                            preventing the spinner from appearing for unsupported SVGs.
	 *                            Should only be true for admin UI uploads, not API/template calls.
	 * @return void
	 */
	private function prepareAndOptimize(Pageimage $img, string $mode, string $engine, array $actions, bool $isAdminUpload = false): void {
		// resmushit doesn't support svg
		if($img->ext === 'svg' && ($this->optimizers['svgo'] === '' || $engine === 'resmushit')) {
			if($isAdminUpload) $this->wire()->config->js('uploadSpinnerMsg', '');
			return;
		}

		// ensure only images with allowed extensions are optimized
		if(!in_array($img->ext, $this->allowedExtensions)) return;

		// make a backup
		if(in_array('backup', $actions)) {
			$backup = substr($img->filename, 0, -(strlen($img->ext) + 1)) . '-autosmush_original.' . $img->ext;
			@copy($img->filename, $backup);
		}

		// optimize
		$result = $this->optimize($img, true, $mode);
		if(is_array($result) && $result['error'] === null) $this->isOptimizedOnUpload = true;
	}

	/**
	 * Hook after InputfieldImage::getImageEditButtons in manual mode.
	 * Add optimize button to the image edit buttons array.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function addOptButton($event) {
		// $event->arguments(0) = Pageimage
		// $event->arguments(3) = $buttonClass (theme-aware, passed by PW)
		// $event->return = array of button HTML strings

		$img = $event->arguments(0);
		if(!$img instanceof Pageimage) return;

		// resmushit doesn't support svg, also check if optimizer is present
		if($img->ext === 'svg'
			&& ($this->optimizers['svgo'] === '' || $this->configData['optManualEngine'] === 'resmushit')) return;

		// ensure only images with allowed extensions are optimized
		if(!in_array($img->ext, $this->allowedExtensions)) return;

		$id = $img->page->id;
		$url = "{$this->wire()->config->urls->admin}module/edit?name=$this&mode=optimize&id=$id&file=$id,{$img->basename}";
		$optimizing = $this->_('Optimizing');
		$text = $this->isOptimizedOnUpload ? $this->_('Optimized on upload') : $this->_('Optimize');
		$rawButtonClass = $event->arguments(3);
		$buttonClass = is_string($rawButtonClass) ? $rawButtonClass : '';
		$icon = "<span class='fa fa-leaf'></span>";
		$buttonText = "<span class='ui-button-text'>$icon <span>$text</span></span>";
		$button = "<button type='button' data-href='$url' data-optimizing='$optimizing' class='InputfieldImageOptimize $buttonClass'>$buttonText</button>";

		/** @var array<string,string> $buttons */
		$buttons = $event->return;
		$buttons['optimize'] = $button;
		$event->return = $buttons;
	}

	/**
	 * Hook after ProcessPageEditImageSelect::executeVariations in manual mode.
	 * Add optimize button to the variations page.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function addOptButtonVariations($event) {

		$opturl = "{$this->wire()->config->urls->admin}module/edit?name=$this&mode=optimize&var=1";
		/** @var InputfieldButton $b */
		$b = $this->wire()->modules->get('InputfieldButton');
		$b->attr('id', 'optimizeVariants');
		$b->attr('data-href', $opturl);
		$b->attr('value', $this->_('Optimize Checked'));
		$b->attr('data-optimizing', $this->_('Optimizing'));
		$b->attr('data-check', $this->_('No variation checked!'));
		$b->icon = 'leaf';
		$b->addClass('InputfieldOptimizeVariants');
		$b->attr('style', 'display:none');

		$needle = "<ul class='Inputfields'>";
		// if there's only the default admin theme, $user->admin_theme is not available
		$adminTheme = $this->wire()->user->admin_theme ? $this->wire()->user->admin_theme : $this->wire()->config->defaultAdminTheme;
		//if($adminTheme == 'AdminThemeUikit') $needle = "<ul class='Inputfields uk-grid-collapse' uk-grid>";
		if($adminTheme === 'AdminThemeUikit') $needle = "<ul class='Inputfields uk-grid-collapse uk-grid-match' uk-grid uk-height-match='target: > .Inputfield:not(.InputfieldStateCollapsed) > .InputfieldContent'>";
		$markup = $event->return;
		if(!is_string($markup)) return;
		if (str_contains($markup, $needle)) {
			$event->return = str_replace($needle, $needle . $b->render(), $markup);
		}
	}

	/**
	 * Hook after InputfieldFile::processInputDeleteFile deletes original uploaded file.
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function deleteBackup($event) {
		$img = $event->argumentsByName('pagefile');
		if(!$img instanceof Pagefile) return;

		$backup = substr($img->filename, 0, -(strlen($img->ext) + 1)) . '-autosmush_original.' . $img->ext;
		//@unlink($img->filename . '.autosmush');
		@unlink($backup);
	}

	/**
	 * Hook after Pageimage::url to return a URL for an optimized variation.
	 * Create a variation image, optimize it and return a URL to this optimized variation.
	 * /site/assets/files/1234/img.jpg -> /site/assets/files/1234/img.-autosmush.jpg
	 *
	 * @param HookEvent $event
	 * @return void
	 */
	public function optimizeOnUrl($event) {
		// DO NOT attempt to dump Pageimage object or access its urls methods as recursion occurs!!!
		$url = $event->return;
		if(!is_string($url)) return;
		//$this->log->save("optimizeOnAccess, url=$url");

		// replace , with |
		$exts = str_replace([', ', ','], '|', self::API_ALLOWED_EXTENSIONS . ', svg');

		//$f = str_replace($this->wire()->config->urls->files, '', $url);
		//$pageid = explode('/', $f)[0]; //sanitize

		// extract page id from url
		//0 => "/site/assets/files/1234/img.jpg"
		//1 => "1234"
		//2 => "img.jpg"
		//3 => "jpg"
		if(! preg_match('~' . $this->wire()->config->urls->files .'(\d+)/([^/]+\.(' . $exts . '))$~i', $url, $match)) {
			$this->log("Invalid image url $url");
			return;
		}
		$pid = $match[1];
		$filename = $this->wire()->sanitizer->filename($match[2]);
		if (str_contains($filename, '-autosmush.')) return; // bypass if it contains this string, as image is already optimized

		$p = $this->wire()->pages->get($pid);
		if(!$p->id) {
			$this->log("Invalid image url $url");
			return;
		}

		$pfm = new PagefilesManager($p);

		// heads up: even you ask for a variation, you get the original
		// https://processwire.com/talk/topic/18230-retrieving-wrong-non-croped-file-with-filesmanager/
		$img = $pfm->getFile($filename); // this is slower: $img = $pfm->getFile($url);
		if(!$img instanceof Pageimage) return;
		// to get a variation:
		// $variation = $img->getVariations()->get($filename);
		// if($variation) $img = $variation;

		// do not attempt to optimize variation
		//if($img->isVariation($varBasename)) return;
		if($this->isVariation($img->basename, $filename)) return; //this is faster

		// resmushit doesn't support svg
		if($img->ext === 'svg' && ($this->optimizers['svgo'] === '' || $this->configData['optApiEngine'] === 'resmushit')) {
			//$this->log->save("Unsupported extension svg"); //disabled to reduce log size, requested by Adrian
			return;
		}

		// ensure only images with allowed extensions are optimized
		if(!in_array($img->ext, $this->allowedExtensions)) {
			$this->log("Unsupported extension " . $img->ext);
			return;
		}

		// construct variation filename eg. C:/inetpub/wwwroot/site/assets/files/1234/img.-autosmush.jpg
		$varFilename = substr($img->filename, 0, -(strlen($img->ext) + 1)) . '-autosmush.' . $img->ext;

		// construct variation basename eg. img.-autosmush.jpg
		$varBasename = substr($img->basename, 0, -(strlen($img->ext) + 1)) . '-autosmush.' . $img->ext;

		// if variation doesn't exist, copy source file to variation file and optimize it
		// Note: getVariations() cannot find '-autosmush' files because PW's variation naming check
		// requires everything up to the first period to match (e.g. 'img-autosmush' != 'img'),
		// so we construct the Pageimage directly from the copied file instead.
		if(!file_exists($varFilename) && @copy($img->filename, $varFilename)) {
			$vimg = new Pageimage($img->pagefiles, $varFilename);
			$result = $this->optimize($vimg, true, 'api');
			if(is_array($result) && $result['error'] === null) $this->isOptimizedOnUpload = true;
		}

		//$optimized = str_replace($match[2], '', $url) . $varBasename;
		$optimized = str_replace($filename, '', $url) . $varBasename;

		// return url with optimized variation image
		$event->return = $optimized;
	}

	/**
	 * Process image optimize via ajax request when optimize link/button is clicked
	 * or in bulk mode
	 *
	 * @param bool $getVariations true when optimizing variation, false if original
	 * @return void
	 */
	public function onclickOptimize($getVariations = false) {

		$err = "<i style='color:red' class='fa fa-times-circle'></i>";
		$input = $this->wire()->input;
		$status = [
			'error'           => null, // various errors
			'error_api'       => null, // errors from reSmush.it
			'percentNew'      => '0',  // reduction percentage
			'file'            => '',   // image name
			'basedir'         => '',   // page id where image is eg. 1234
			'url'             => '#',  // full url to the image
		];

		$file = $input->get->text('file'); // 1234,image.jpg
		$id = $input->get->int('id'); // could also get id from file var
		$isBulk = $input->get->int('bulk') === 1;
		$m = $isBulk ? 'bulkOptimize: ' : 'onclickOptimize: ';

		if($this->wire()->config->demo) {
			$msg = $this->msgs['demo'];
			$this->log($m . $msg);
			if($isBulk) {
				$status['error'] = $msg;
				header('Content-Type: application/json');
				echo json_encode($status);
			} else {
				echo $getVariations ? $err : $msg;
			}
			exit(0);
		}

		$page = $this->wire()->pages->get($id);

		if(!$id || !$file || !$page->id) {
			$msg = 'Invalid data!';
			$this->log($m . $msg);
			if($isBulk) {
				$status['error'] = 'invalid data';
				header('Content-Type: application/json');
				echo json_encode($status);
			} else {
				echo $getVariations ? $err : $msg;
			}
			exit(0);
		}

		$fileParts = explode(',', $file, 2);
		$fileName = isset($fileParts[1]) ? $fileParts[1] : '';
		$status['file'] = $this->wire()->config->urls->files . $id . '/' . $fileName; // fake image name
		$status['basedir'] = $id; // page id where image is eg. 1234

		// this doesn't work with CroppableImage3
		//$img = wire('modules')->get('ProcessPageEditImageSelect')->getPageImage($getVariations);

		$myimage = $this->getPageimage($page, true);

		if(!$myimage) {
			$file = $fileName;
			$msg = ' not found!';
			$this->log($m . $file . $msg);
			if($isBulk) {
				$status['error'] = 'image not found';
				if(pathinfo($file, PATHINFO_EXTENSION) === 'webp') $status['error'] = 'unsupported image type';
				header('Content-Type: application/json');
				echo json_encode($status);
			} else {
				echo $getVariations ? $err : $msg;
			}
			exit(0);
		}

		$img = $myimage;

		$src_size = (int) @filesize($img->filename);
		if($src_size === 0) {
			// this shouldn't happen but who knows
			if($isBulk) {
				$status['error'] = 'zero file size';
				header('Content-Type: application/json');
				echo json_encode($status);
			} else {
				echo 'Zero file size!';
			}
			exit(0);
		}

		if($isBulk) {
			$status = $this->optimize($img, true, 'bulk');
			if(!is_array($status)) {
				$status = [
					'error' => 'optimize failed',
					'error_api' => null,
					'percentNew' => '0',
					'file' => $img->basename,
					'basedir' => basename(dirname($img->filename)),
					'url' => ''
				];
			}
			header('Content-Type: application/json');
			echo json_encode($status);
			exit(0);
		} else {
			$status = $this->optimize($img, true, 'manual');
			if(!is_array($status)) {
				echo $getVariations ? $err : $this->_('Not optimized, check log!');
				exit(0);
			}
			if($status['error'] !== null) {
				$msg = $this->_('Not optimized, check log!');
				// errors are already logged by optimize method
				echo $getVariations ? $err : $msg;
				exit(0);
			}
			if($status['skipped'] !== null) {
				@clearstatcache(true, $img->filename);
				$size = @filesize($img->filename) ?: 0;
				echo $getVariations ? wireBytesStr($size) : $this->_('Already optimal (below threshold)');
				exit(0);
			}
		}

		@clearstatcache(true, $img->filename);
		$dest_size = @filesize($img->filename);
		if($dest_size === false) $dest_size = 0;

		if($getVariations) {
			echo wireBytesStr($dest_size);
		} else {
			//$percentNew = 100 - (int) ($dest_size / $src_size * 100);
			//printf($this->x_x('Optimized, reduced by %1$d%%'), $percentNew);
			echo $this->_('Optimized, new size:') . ' ' . wireBytesStr($dest_size);
		}

		exit(0);
	}

	/**
	 * Create a list of images to be optimized and echo it in JSON format.
	 * Called from the module settings in bulk mode on button click.
	 *
	 * @return void
	 */
	public function bulkOptimize() {

		// check if engine is selected
		if(!isset($this->configData['optBulkEngine'])) {
			$this->log('No engine selected (bulk).');
			$status = [
				'error' => 'No engine selected.',
				'numImages' => 0
			];
			header('Content-Type: application/json');
			echo json_encode($status);
			exit(0);
		}

		$processOriginals  = in_array('optimize_originals', $this->configData['optBulkAction']);
		$processVariations = in_array('optimize_variations', $this->configData['optBulkAction']);

		// get all fields of type FieldtypeImage or CroppableImage fieldtypes
		$selector = 'type=FieldtypeImage';
		if($this->wire()->modules->isInstalled('FieldtypeCroppableImage4')) $selector .= '|FieldtypeCroppableImage4';
		if($this->wire()->modules->isInstalled('FieldtypeCroppableImage3')) $selector .= '|FieldtypeCroppableImage3';
		$imageFields = $this->wire()->fields->find($selector);

		// get total number of pages with images
		$numPagesWithImages = 0;
		foreach ($imageFields as $f) $numPagesWithImages += $this->wire()->pages->count("$f>0, include=all");

		$allImages = [];
		$limit = 1;
		$start = abs($this->wire()->input->get->int('start'));
		if($start >= $numPagesWithImages) $start = $numPagesWithImages;

		// get all images from pages that have image fields
		foreach ($imageFields as $f) {
			/** @var Field $f */
			$fieldName = $f->name;
			foreach ($this->wire()->pages->find("$fieldName>0, include=all, start=$start, limit=$limit") as $p) {
				$images = $p->getUnformatted($fieldName);
				if(!$images instanceof Pageimages) continue;
				$id = $p->id;
				$filesArray = false;

				foreach ($images as $i) {
					if(!$i instanceof Pageimage) continue;
					if($processOriginals) $allImages[] = "$id,{$i->basename}";

					if($processVariations) {

						// create array of files in pagefiles folder eg. /site/assest/files/1234/
						if($filesArray === false) {
							$fileList = @scandir($i->pagefiles->path);
							$filesArray = is_array($fileList)
								? array_values(array_diff($fileList, ['.', '..', $i->basename]))
								: [];
						}

						// iterate over array of files and check if file is variation of current image
						foreach($filesArray as $file) {
							if(!is_string($file)) continue;
							// exclude file.-autosmush.jpg variations?
							if($this->isVariation($i->basename, $file)) $allImages[] = "$id,$file";
						}
					}
				}
			}
		}

		$totalImages = count($allImages);
		$a = [];
		if($start < $numPagesWithImages) {
			$a["counter"] =	sprintf($this->_('Processing page %1$d out of %2$d - {%3$d}%% complete'), // {} is placeholder, must be present
											$start+1, $numPagesWithImages, (int) ($start / $numPagesWithImages * 100));
		} else {
			$a["counter"] =	sprintf($this->_('All done - {100}%% complete'));
		}
		$a["numBatches"] = $numPagesWithImages;
		$a["numImages"] = $totalImages;
		$a["images"] = $allImages;
		header('Content-Type: application/json');
		echo json_encode($a);
		exit(0);

	}

	/**
	 * Optimize image
	 *
	 * @param Pageimage $img Pageimage object
	 * @param bool $force true when you want to force optimization
	 * @param string $mode 'auto', 'api', 'manual' or 'bulk'
	 * @return array<string,string|null>|false
	 */
	public function optimize($img, $force = false, $mode = 'auto'): array|false {
		// note: optimized file overwrites original!
		// someday test with $config->pagefileExtendedPaths = true
		// and maybe make optimizers as separate methods that takes just filename, no need for pageimage object

		$demo = $this->wire()->config->demo;

		$status = [
			'error'           => null, // various errors
			'error_api'       => null, // errors from reSmush.it
			'percentNew'      => '0', // reduction percentage
			'skipped'         => null, // reason if optimization was skipped
			'file'            => $img->basename, // image name
			'basedir'         => basename(dirname($img->filename)), // page id where image is eg. 1234
			//'url'             => $img->httpUrl // would cause infinite recursion via Pageimage::url hook in API mode
			'url'             => $img->pagefiles->url() . $img->basename // bypass the hook by using pagefiles->url() directly
		];

		// force is only used in optimizeOnUpload
		// When auto-mode optimization is skipped because no resize/crop event occurred,
		// the method returns false instead of a status array.
		if(!$force && !$this->isOptimizeNeeded) return false;

		if(!in_array($img->ext, $this->allowedExtensions)) {
			$error = "($mode): Error optimizing " . $img->filename . ": unsupported extension";
			$this->log($error);
			$status['error'] = 'unsupported extension';
			return $status;
		}

		$opt = '';
		$src_size = 0;
		$dest_size = 0;
		$percentNew = 0;
		$mode1 = ucfirst(strtolower($mode)); // must match config settings: Auto, Api, Manual, Bulk
		/** @var int|string $qValue */
		$qValue = $this->configData["opt{$mode1}Quality"] ?? self::JPG_QUALITY_DEFAULT;
		$q = (string) $qValue;

		// Build a local copy of optimizer settings with the quality flag appended.
		// Using a local copy avoids mutating shared state ($this->optimizeSettings) across
		// multiple optimize() calls in the same request (e.g. bulk mode).
		$localSettings = $this->optimizeSettings;
		if(!is_array($localSettings['jpegoptim_options'] ?? null)) {
			$localSettings['jpegoptim_options'] = [];
		}
		/** @var array<string> $jpegOptions */
		$jpegOptions = $localSettings['jpegoptim_options'];
		$jpegOptions[] = '-m' . $q;
		$localSettings['jpegoptim_options'] = array_unique($jpegOptions);

		if($this->configData["opt{$mode1}Engine"] === 'resmushit') {
			// use resmush.it web service
			$opt = "reSmush.it ($mode): ";

			if($img->filesize >= self::API_SIZELIMIT) {
				$error = 'Error optimizing ' . $img->filename . ', file larger then ' . self::API_SIZELIMIT . ' bytes';
				$this->log($opt . $error);
				$status['error'] = 'file too large';
				return $status;
			}

			// upload image using WireHttp class
			$http = new WireHttp();
			$http->setTimeout(self::CONNECTION_TIMEOUT); // important!!! default is 4.5 sec and that is to low
			$multipart = $this->buildMultipartFormData($img);
			$http->setHeader('Content-Type', 'multipart/form-data; boundary=' . $multipart['boundary']);
			$url = self::WEBSERVICE;
			if((int) ($this->configData['optNoExif'] ?? 0) === 1) {
				$url = self::WEBSERVICE_NOEXIF;
			}
			$data = $http->post($url . '&qlty=' . $q, $multipart['content']);

			if(!is_string($data)) {
				$error = 'Error optimizing ' . $img->filename . ', ';
				$error1 = (string) $http->getHttpCode(true);
				$this->log($opt . $error . $error1);
				$status['error'] = $error1;
				return $status;
			}

			$response = json_decode($data, true);

			if(!is_array($response)) {
				$error = 'Error optimizing ' . $img->filename . ', returned data is empty';
				$this->log($opt . $error);
				$status['error'] = 'returned data is empty';
				return $status;
			}

			$errorCode = isset($response['error']) && (is_int($response['error']) || is_string($response['error']))
				? (string) $response['error']
				: null;

			if($errorCode !== null) {
				$error = isset($this->apiErrorCodes[$errorCode]) ? $this->apiErrorCodes[$errorCode] : $errorCode;
				$this->log($opt . 'Error optimizing ' . $img->filename . ', ' . $error);
				$status['error'] = $error;
				$status['error_api'] = $error;
				return $status;
			}

			/** @var array{dest_size:int|float|string, src_size:int|float|string, dest:string, percent:int|float|string} $response */
			$dest_size = (int) $response['dest_size'];
			$src_size = (int) $response['src_size'];
			$dest = $response['dest'];

			// write to file only if optimized image is smaller by more than the threshold
			if($dest_size < (int) ((100 - self::JPG_QUALITY_THRESHOLD) / 100 * $src_size)) {

				//$http = new WireHttp();
				//$http->setTimeout(self::CONNECTION_TIMEOUT);
				try {
					if(!$demo) $http->download($dest, $img->filename);//, ['useMethod' => 'fopen']);
					//$percentNew = 100 - (int) ($response->dest_size / $response->src_size * 100);
					$percentNew = (int) $response['percent'];
				} catch(Exception $e) {
					$error = 'Error retrieving ' . $dest . ', ' . $e->getMessage();
					$this->log($opt . $error);
					$status['error'] = $e->getMessage();
					return $status;
				}
			} else {
				// optimized image did not meet the size reduction threshold, original is kept
				$this->log($opt . $img->filename . ': skipped, reduction below threshold (' . self::JPG_QUALITY_THRESHOLD . '%)');
				$status['skipped'] = 'below threshold';
			}
		}

		elseif($this->configData["opt{$mode1}Engine"] === 'localtools') {
			// use local (server) tools
			$opt = "ServerTools ($mode): ";

			$src_size = filesize($img->filename);
			if($src_size === false) {
				$this->log($opt . 'Error reading file size of ' . $img->filename);
				$status['error'] = 'could not read source file size';
				return $status;
			}

			$factory = new OptimizerFactory($localSettings);
			$optimizer = $factory->get();
			//$optimizer = $factory->get('jpegoptim');

			try {
				// optimizer will throw an exception if none of the optimizers in chain are found
				if(!$demo) $optimizer->optimize($img->filename);  // optimized file overwrites original!
			} catch (ImageOptimizerException $e) {
				$error = $e->getMessage();
				$this->log($opt . 'Error optimizing ' . $img->filename . ', ' . $error);
				$status['error'] = $error;
				return $status;
			}

			clearstatcache(true, $img->filename);
			$dest_size = filesize($img->filename);
			if($dest_size === false) {
				$this->log($opt . 'Error reading file size of ' . $img->filename . ' after optimization');
				$status['error'] = 'could not read destination file size';
				return $status;
			}
			$percentNew = $src_size > 0 ? 100 - (int) ($dest_size / $src_size * 100) : 0;

		} else {
			// no engine selected
			$opt = "No engine selected ($mode). ";
			$src_size = filesize($img->filename) ?: 0;
			$this->log($opt . $img->filename . ', source ' . $src_size . ' bytes');
			$status['error'] = 'No engine selected.';
			return $status;
		}

		// image is optimized
		$this->log($opt . $img->filename . ', source ' . $src_size . ' bytes, destination ' . $dest_size . ' bytes, reduction ' . $percentNew . '%');
		$status['percentNew'] = (string) $percentNew;
		return $status;

	}

	/**
	 * Build multipart/form-data body for reSmush.it uploads.
	 *
	 * @param Pageimage $img
	 * @return array<string,string>
	 */
	private function buildMultipartFormData(Pageimage $img): array {
		$eol = "\r\n";
		$boundary = strtolower(md5((string) time()));
		$content = '';
		$content .= '--' . $boundary . $eol;
		$content .= 'Content-Disposition: form-data; name="files"; filename="' . $img->basename . '"' . $eol;
		$content .= 'Content-Type: image/' . $img->ext . $eol . $eol; // two eol's!!!!!
		$fileData = file_get_contents($img->filename);
		if($fileData === false) return ['boundary' => $boundary, 'content' => ''];
		$content .= $fileData . $eol;
		$content .= '--' . $boundary . '--' . $eol;

		return [
			'boundary' => $boundary,
			'content' => $content,
		];
	}

	/**
	 * Module fields
	 *
	 * @param array<string,mixed> $data config data
	 * @return InputfieldWrapper
	 */
	public function getModuleConfigInputfields($data) {

		$fields = new InputfieldWrapper();
		$modules = $this->wire()->modules;
		$config = $this->wire()->config;

		/** @var AutoSmushConfigData $data */
		$data = array_merge($this->configData, $data);

		if($config->demo) $this->error($this->msgs['demo']);

		// automatic mode in admin (backend)
		/** @var InputfieldFieldset $fieldset */
		$fieldset              = $modules->get('InputfieldFieldset');
		$fieldset->label       = $this->_('Automatic Mode in Admin (backend)');
		$fieldset->description = $this->_('Automatically optimize images on upload (originals) or on resize/crop (variations).');
		$fields->add($fieldset);

		/** @var InputfieldRadios $field */
		$field                = $modules->get('InputfieldRadios');
		$field->name          = 'optAutoEngine';
		$field->label         = $this->msgs['engine'];
		$field->columnWidth   = 40;
		$field->addOption('resmushit',  $this->msgs['eng_resmushit']);
		$field->addOption('localtools', $this->msgs['eng_localtools']);
		$field->value         = $data['optAutoEngine'];
		$fieldset->add($field);

		/** @var InputfieldCheckboxes $field */
		$field                = $modules->get('InputfieldCheckboxes');
		$field->name          = 'optAutoAction';
		$field->label         = $this->msgs['actions'];
		$field->columnWidth   = 40;
		$field->addOption('optimize_originals', $this->_('Optimize on upload'));
		$field->addOption('backup', $this->_('Backup original'));
		$field->addOption('optimize_variations', $this->_('Optimize on resize/crop'));
		if($modules->isInstalled('FieldtypeCroppableImage4') || $modules->isInstalled('FieldtypeCroppableImage3')) {
			$field->addOption('optimize_variationsCI3', $this->_('Optimize on resize/crop for CroppableImage 3/4'));
		}
		$field->value         = $data['optAutoAction'];
		$fieldset->add($field);

		/** @var InputfieldInteger $field */
		$field                = $modules->get('InputfieldInteger');
		$field->name          = 'optAutoQuality';
		$field->label         = $this->msgs['jpg_quality'];
		$field->columnWidth   = 20;
		$field->attr('min', '1');
		$field->attr('max', '100');
		$field->value         = $data['optAutoQuality'];
		$fieldset->add($field);


		// automatic mode in templates (frontend)
		/** @var InputfieldFieldset $fieldset */
		$fieldset              = $modules->get('InputfieldFieldset');
		$fieldset->label       = $this->_('Automatic Mode in T'.'emplates (frontend API)');
		$fieldset->description = $this->_('Automatically optimize images on API calls (url, add, size).');
		$fields->add($fieldset);

		/** @var InputfieldRadios $field */
		$field                = $modules->get('InputfieldRadios');
		$field->name          = 'optApiEngine';
		$field->label         = $this->msgs['engine'];
		$field->columnWidth   = 40;
		$field->addOption('resmushit',  $this->msgs['eng_resmushit']);
		$field->addOption('localtools', $this->msgs['eng_localtools']);
		$field->value         = $data['optApiEngine'];
		$fieldset->add($field);

		/** @var InputfieldCheckboxes $field */
		$field                = $modules->get('InputfieldCheckboxes');
		$field->name          = 'optApiAction';
		$field->label         = $this->msgs['actions'];
		$field->columnWidth   = 40;
		$field->addOption('optimize_auto', $this->_('Optimize on Pageimage->url() [EXPERIMENTAL]'));
		$field->addOption('optimize_originals', $this->_('Optimize on Pageimage->add()'));
		//$field->addOption('backup', $this->_('Backup original'));
		$field->addOption('optimize_variations', $this->_('Optimize on Pageimage->size()/width()/height()/crop()'));
		//$field->addOption('optimize_api', $this->_('Optimize on API resize/add'));
		$field->value         = $data['optApiAction'];
		$fieldset->add($field);

		/** @var InputfieldInteger $field */
		$field                = $modules->get('InputfieldInteger');
		$field->name          = 'optApiQuality';
